<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="ElegancePU" transaction-type="JTA">

        <jta-data-source>jdbc/Elegance1DB</jta-data-source>

        <class>com.mycompany.eleganceapp.model.User</class>
        <class>com.mycompany.eleganceapp.model.Article</class>
        <class>com.mycompany.eleganceapp.model.Category</class>
        <class>com.mycompany.eleganceapp.model.Order</class>
        <class>com.mycompany.eleganceapp.model.OrderItem</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="none"/>
            <property name="jakarta.persistence.logging.level"
                      value="INFO"/>
        </properties>

    </persistence-unit>
</persistence>

